
# ── LLM CONFIGURATION ────────────────────────────────────────────────────────
GROQ_API_KEY=gsk_your_key_here
LLM_MODEL=llama-3.1-8b-instant

# ── SMTP CONFIGURATION ───────────────────────────────────────────────
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@example.com
SMTP_PASSWORD=your-app-specific-password
SMTP_SENDER_NAME=Finance Department

# ── PAYMENT INFRASTRUCTURE ───────────────────────────────────────────────────
PAYMENT_LINK=https://payments.example.com/portal
BANK_DETAILS=IBAN: GB00 0000 0000 0000 | SWIFT: EXAMPLEX

# ── AUTOMATION & SCHEDULING ──────────────────────────────────────────────────
# SCHEDULE_HOUR: The hour (0-23) when the daily automated run should trigger.
# TIMEZONE: The timezone for the daily run (e.g., Asia/Kolkata, UTC).
SCHEDULE_HOUR=9
TIMEZONE=Asia/Kolkata

# ── RUN MODE ─────────────────────────────────────────────────────────────────
# DRY_RUN=true  -> Generates emails and logs them to 'outputs/' only (Safe mode)
# DRY_RUN=false -> Actually sends emails via the SMTP server configured above
DRY_RUN=true
