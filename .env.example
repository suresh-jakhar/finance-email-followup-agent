
# LLM config
GROQ_API_KEY=gsk_your_key_here
LLM_MODEL=llama-3.1-8b-instant

#  SMTP config 
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@example.com
SMTP_PASSWORD=your-app-specific-password
SMTP_SENDER_NAME=Finance Department

# Payment details {to be sent in mail to recieve payment}
PAYMENT_LINK=https://payments.example.com/portal
BANK_DETAILS=IBAN: GB00 0000 0000 0000 | SWIFT: EXAMPLEX

# SCHEDULE_HOUR: The hour (0-23) when the daily automated run should trigger.
# TIMEZONE: The timezone for the daily run (e.g., Asia/Kolkata, UTC).
SCHEDULE_HOUR=9
TIMEZONE=Asia/Kolkata

# DRY_RUN=true  -> Generates emails and logs them to 'outputs/' only
# DRY_RUN=false -> sends emails via the SMTP server configured above
DRY_RUN=true
